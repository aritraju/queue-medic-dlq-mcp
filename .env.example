# ─────────────────────────────────────────────
#  Queue Medic — environment variable template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Google Gemini API key (free tier: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — gemini-3.1-flash-lite is the default (fast, free-tier compatible)
GEMINI_MODEL=gemini-3.1-flash-lite

# RabbitMQ connection string (matches the Docker Compose defaults)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# RabbitMQ topology names
PRIMARY_EXCHANGE=events_exchange
DLX_EXCHANGE=dlx_exchange
PRIMARY_QUEUE=events_queue
DEAD_LETTER_QUEUE=dead_letter_queue

# DuckDB file path (relative to project root)
DUCKDB_PATH=data/events.duckdb

# Documentation directory (relative to project root)
DOCS_DIR=docs
